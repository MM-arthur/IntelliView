# LLM API Keys (at least one required)
MOONSHOT_API_KEY=your_moonshot_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# Custom Model (optional)
API_custom_model_username=your_username
API_custom_model_password=your_password
API_custom_model_url=your_api_base_url

# Model settings
MOONSHOT_MODEL=moonshot-v1-8k

# Embedding settings
EMBEDDING_MODEL=qwen3-embedding-0.6b
EMBEDDING_MODEL_NAME_PATH=/path/to/embedding/model

# RAG knowledge base
RAG_KNOWLEDGE_BASE=/path/to/knowledge/base

# Speech engine
SPEECH_ENGINE=sensevoice

# Current date (optional)
CURRENT_DATE=2026-05-31

# Tavily search
TAVILY_API_KEY=your_tavily_key_here
